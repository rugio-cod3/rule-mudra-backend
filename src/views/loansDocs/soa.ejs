<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Statement of Account</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
    }

    .container {
      width: 100%;
      max-width: 800px;
      margin: 0 auto;
      padding: 20px;
      box-sizing: border-box;
    }

    .header {
      text-align: center;
      margin-bottom: 20px;
    }

    .header img {
      max-width: 100px;
      margin-bottom: 10px;
    }

    .header h1 {
      font-size: 24px;
      margin: 0;
    }

    .header h2 {
      font-size: 20px;
      margin: 5px 0;
    }

    .horizontal-line {
      border-top: 1px solid #000;
      margin: 10px 0;
    }

    .section {
      margin-bottom: 20px;
    }

    .detail-row {
      margin-bottom: 5px;
    }

    .detail-row span {
      display: inline-block;
      width: 48%;
      box-sizing: border-box;
    }

    .bold {
      font-weight: bold;
    }

    .content {
      width: 100%;
    }

    .left,
    .right {
      display: inline-block;
      width: 48%;
      vertical-align: top;
    }

    .date {
      text-align: left;
      margin-bottom: 20px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
    }

    table th,
    table td {
      padding: 8px;
      border: 1px solid #ddd;
      text-align: left;
    }

    table th {
      background-color: #f2f2f2;
    }

    .custom-color {
      color: black;
      background-color: rgb(63, 65, 61);
    }
  </style>
</head>

<body>
  <div class="container">
    <div class="date">
      <p><strong>Date: </strong>
        <%= data.date %>
      </p>
    </div>
    <div class="header">
      <img
        src="data:image/png;base64,"
        alt="ramfincorp Logo" style="max-width: 200px; height: auto" />
      <h1>Ram Fincorp</h1>
      <h2>Statement of Account</h2>
      <p>From <%= data.fromDate %> to <%= data.toDate %>
      </p>
    </div>
    <div class="horizontal-line"></div>
    <div class="section">
      <div class="content"></div>
      <div class="left">
        <div class="detail-row">
          <span class="bold">Customer Name:</span>
          <span>
            <%= data.customer.name %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Loan No.:</span>
          <span>
            <%= data.loan.loanNo %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">PAN No.:</span>
          <span>
            <%= data.customer.pancard %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Address:</span>
          <span>
            <%= data.address.address %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Mobile No.:</span>
          <span>
            <%= data.customer.mobile %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Product:</span>
          <span>
            <%= data.loan.product %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Disbursal Date:</span>
          <span>
            <%= data.loan.disbursalDate %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Installment Period:</span>
          <span>
            <%= data.emi.installmentPeriod %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">EMI Amount:</span>
          <span>
            <%= data.emi.emiAmount %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Rate of Interest (Annual):</span>
          <span>
            <%= data.emi.roi %>%
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Pentalty Interest (Annual):</span>
          <span>
            <%= data.emi.penaltyInterest %>%
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Write Off Amount</span>
          </br>
          </br>
          &nbsp;
          <span>Principle:</span>
          <span>
            <%= data.emi.writeOffAmount.principle %>
          </span>
          &nbsp;
          <span>Interest:</span>
          <span>
            <%= data.emi.writeOffAmount.interest %>
          </span>
          &nbsp;
          <span>Charges:</span>
          <span>
            <%= data.emi.writeOffAmount.charges %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">DPD:</span>
          <span>
            <%= data.emi.dpd %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Restructured</span>
          <span>
            <%= data.emi.restructured %>
          </span>
        </div>
      </div>
      <div class="right">
        <div class="detail-row">
          <span class="bold">Processing Fee (One Time):</span>
          <span>
            <%= data.emi.processingFee %>%
          </span>
        </div>

        <div class="detail-row">
          <span class="bold">GST on Processing Fee:</span>
          <span>
            <%= data.emi.gst %>%
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Tenure in Months:</span>
          <span>
            <%= data.emi.tenure %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Loan Amount:</span>
          <span>
            <%= data.emi.loanAmount %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Disbursed Amount:</span>
          <span>
            <%= data.emi.disbursedAmount %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Repayment Amount:</span>
          <span>
            <%= data.emi.repayAmount %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Installment Overdue:</span>
          <span>
            <%= data.emi.installmentOverdue %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Installment Paid:</span>
          <span>
            <%= data.emi.installmentPaid %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Principle Paid:</span>
          <span>
            <%= data.emi.principlePaid %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Interest Paid:</span>
          <span>
            <%= data.emi.interestPaid %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Other Charges Paid:</span>
          <span>
            <%= data.emi.otherChargesPaid %>
          </span>
        </div>
        <div class="detail-row">
          <span class="bold">Outstanding Amount:</span>
          <span>
            <%= data.emi.outstandingAmount %>
          </span>
        </div>
      </div>
    </div>
    <div class="horizontal-line"></div>
    <div class="section">
      <table>
        <tr class="custom-color">
          <th>Txn Date</th>
          <th>Particular</th>
          <th>Debit</th>
          <th>Credit</th>
          <th>Closing Balance</th>
        </tr>
        <% data.transactions.forEach(transaction=> { %>
          <tr>
            <td class="col_css">
              <%= transaction.txnDate %>
            </td>
            <td class="col_css">
              <%= transaction.particular %>
            </td>
            <td class="col_css">
              <%= transaction.debit %>
            </td>
            <td class="col_css">
              <%= transaction.credit %>
            </td>
            <td class="col_css">
              <%= transaction.closingBalance %>
            </td>
          </tr>
        <% }) %>
      </table>
    </div>
    <div class="horizontal-line"></div>
    <div class="section">
      <table>
        <tr>
          <th class="custom-color">Total</th>
          <td class="col_css" style="width:300px"></td>
          <td class="col_css"> Rs. <%= data.totalDebit %></td>
          <td class="col_css"> Rs <%= data.totalCredit %></td>
          <td class="col_css" style="width:100px"></td>
        </tr>
      </table>
    </div>
  </div>
</body>

</html>