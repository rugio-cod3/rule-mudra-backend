<!DOCTYPE html>
<html>

<head>
  <style>
    a {
      text-decoration: none;
    }

    p {
      font-family: math;
      font-size: large;
    }

    .header {
      cursor: pointer;
      display: inline-flex !important;
      align-items: center;
      transition: all .135s ease-in-out;
      transform: scale(1.001);
      color: #fff !important;
      background-color: #3273e4 !important;
      width: 98%;
      height: 110px;
      border-radius: 15px;
      font-size: xxx-large;
    }

    .btn {
      cursor: pointer;
      display: inline-flex !important;
      align-items: center;
      justify-content: center;
      transition: all .135s ease-in-out;
      transform: scale(1.001);
    }

    .primery {
      color: #fff !important;
      background-color: #42bf33 !important;
      width: -webkit-fill-available;
      height: 50px;
      border-radius: 15px;
      font-size: xx-large;
    }

    .container {
      --bs-gutter-x: 1.5rem;
      --bs-gutter-y: 0;
      padding-right: calc(var(--bs-gutter-x)* 3.5);
      padding-left: calc(var(--bs-gutter-x)* 3.5);
    }

    .gap-2 {
      padding: 7px;
    }
  </style>
</head>

<body>
  <table style="width: 850px; border: 1px solid white;">
    <tr>
      <td colspan="2">
        <a href="https://ramfincorp.com" class="header" style="padding: 20px 0px 0px 36px; width: -webkit-fill-available;">
